#!/usr/bin/env python3
# tools/compare_programs.py
import json
from pathlib import Path
from collections import Counter, defaultdict

repo = Path.cwd()
decoded_path = repo / 'assets' / 'programs' / 'Programs_decoded_full.json'
ui_path = repo / 'assets' / 'programs.json'

def load_strip_comments(p: Path):
    s = p.read_text(encoding='utf-8')
    lines = []
    for ln in s.splitlines():
        stripped = ln.strip()
        if stripped.startswith('//'):
            continue
        lines.append(ln)
    return json.loads('\n'.join(lines))

if not decoded_path.exists():
    print('ERROR: Programs_decoded_full.json not found at', decoded_path); raise SystemExit(1)
if not ui_path.exists():
    print('ERROR: programs.json not found at', ui_path); raise SystemExit(1)

decoded = load_strip_comments(decoded_path)
ui = load_strip_comments(ui_path)

# Count total decoded
total_decoded = len(decoded)

# Collect UI programs (categories + subcategories). This assumes the structure used in your repo.
ui_programs = []
for cat in ui.get('categories', []):
    for p in cat.get('programs', []):
        ui_programs.append(p)
    for sub in cat.get('subcategories', []):
        for p in sub.get('programs', []):
            ui_programs.append(p)

total_ui = len(ui_programs)

# Build lookups for decoded
decoded_by_uuid = {e.get('ProgramUUID'): e for e in decoded if e.get('ProgramUUID')}
decoded_by_internal = {e.get('internalID'): e for e in decoded if e.get('internalID') is not None}

# Build lookups for UI
ui_by_uuid = {p.get('uuid'): p for p in ui_programs if p.get('uuid')}
ui_by_internal = {}
for p in ui_programs:
    # note: in your UI file keys use internalId (camelCase) or internalId - handle both generically
    iid = None
    if 'internalId' in p and p.get('internalId') is not None:
        iid = p.get('internalId')
    elif 'internalID' in p and p.get('internalID') is not None:
        iid = p.get('internalID')
    if iid is not None:
        try:
            ui_by_internal[int(iid)] = p
        except:
            pass

# 3a) decoded entries missing in UI (neither ProgramUUID nor internalID present in UI)
missing_decoded = []
for uuid, entry in decoded_by_uuid.items():
    iid = entry.get('internalID')
    if (uuid not in ui_by_uuid) and (iid not in ui_by_internal):
        missing_decoded.append({'uuid': uuid, 'internalID': iid, 'level': entry.get('level')})

# 3b) UI entries that have no decoded counterpart
ui_without_decoded = []
for uuid, p in ui_by_uuid.items():
    if uuid not in decoded_by_uuid:
        ui_without_decoded.append({'uuid': uuid, 'internalId': p.get('internalId')})
for iid, p in ui_by_internal.items():
    if iid not in decoded_by_internal:
        if not any(x.get('internalId') == iid for x in ui_without_decoded):
            ui_without_decoded.append({'uuid': p.get('uuid'), 'internalId': iid})

# 4) Group missing_decoded by 'level' (counts + examples)
level_counts = Counter()
level_examples = defaultdict(list)
for e in missing_decoded:
    lvl = e.get('level')
    level_counts[lvl] += 1
    if len(level_examples[lvl]) < 5:
        level_examples[lvl].append((e['uuid'], e['internalID']))

# Output
print('--- Program Catalog Comparison Report ---')
print('Total programs in Programs_decoded_full.json:', total_decoded)
print('Total program entries found in assets/programs.json (catalog):', total_ui)
print()
print('Decoded entries NOT referenced in UI (by ProgramUUID or internalID):', len(missing_decoded))
for lvl in sorted(level_counts.keys(), key=lambda x: (x is None, x)):
    print(f'  level {lvl}: {level_counts[lvl]} missing (examples: {level_examples[lvl]})')
print()
print('UI entries WITHOUT decoded match (count):', len(ui_without_decoded))
print('Examples (up to 5):')
for i, ex in enumerate(ui_without_decoded[:5], start=1):
    print(f'  {i}. uuid={ex.get("uuid")} internalId={ex.get("internalId")}')
print()
print('Examples of decoded entries missing in UI (up to 5):')
for i, e in enumerate(missing_decoded[:5], start=1):
    print(f'  {i}. uuid={e.get("uuid")} internalID={e.get("internalID")} level={e.get("level")}')
print('--- end report ---')
python3 tools/compare_programs.py


